{
  "name": "agent-deck",
  "version": "0.1.4",
  "description": "A local-first Electron control deck for vibecoding: cross-agent usage & quota, Agent Skills, conversation history, and a project command center for Claude Code & Codex.",
  "author": "Agent Deck contributors",
  "license": "MIT",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "electron": "electron .",
    "start": "concurrently -k \"npm run dev\" \"wait-on http://127.0.0.1:5173 && npm run electron\"",
    "test": "node --test tests/*.test.mjs",
    "check": "npm run test && tsc --noEmit && vite build && node --check electron/main.cjs && node --check electron/preload.cjs && node --check scripts/capture-screenshots.cjs",
    "qa:screenshot": "node scripts/capture-screenshots.cjs",
    "build": "vite build",
    "package:win": "electron-builder --win portable --x64"
  },
  "dependencies": {
    "ccusage": "^20.0.5",
    "dompurify": "^3.4.7",
    "lucide-react": "^0.554.0",
    "marked": "^18.0.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tokscale": "^2.1.3",
    "undici": "^6.26.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "electron": "^42.3.2",
    "electron-builder": "^26.8.1",
    "playwright-core": "^1.60.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "dev.agentdeck.app",
    "productName": "Agent Deck",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "build/icon.ico",
      "build/icon.png",
      "build/icon.svg",
      "config/**/*",
      "node_modules/ccusage/**/*",
      "node_modules/tokscale/**/*",
      "node_modules/undici/**/*",
      "package.json"
    ],
    "icon": "build/icon.ico",
    "asarUnpack": [
      "node_modules/ccusage/**/*",
      "node_modules/tokscale/**/*"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "AgentDeck-${version}-${arch}.exe"
    }
  }
}
